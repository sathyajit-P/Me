<section class="min-h-[calc(100vh-120px)] flex items-center py-8">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center text-center lg:text-left">
    <div>
      <h1 class="font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl leading-[1.1] mb-6 tracking-tight">
        <div class="mb-6">Hello, I'm Sathyajit P Udupa</div>
        <span class="text-gradient">Web Developer</span>
      </h1>
      <p class="font-sans text-xl text-zinc-600 mb-10 max-w-lg mx-auto lg:mx-0 leading-relaxed">
        I just experiment and try building tools which solves problems
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
        <a href="/Me/projects" class="btn btn-primary w-full sm:w-auto">View Projects</a>
        <a href="/Me/contact" class="btn btn-outline w-full sm:w-auto">Contact Me</a>
      </div>
    </div>
    
    <div class="relative flex flex-col items-center">
      <div class="relative w-full max-w-[400px] h-[400px] lg:h-[450px] rounded-3xl z-10 group">
        <img src="/Me/pic.jpg" alt="Profile avatar" class="w-full h-full object-cover rounded-3xl relative z-20 shadow-2xl transition-transform duration-500 group-hover:-translate-y-2" />
        <div class="absolute top-5 -right-2.5 lg:-right-5 w-full h-full border-4 border-red rounded-3xl z-0 transition-transform duration-500 group-hover:translate-x-2 group-hover:translate-y-2"></div>
      </div>
    </div>
  </div>
</section>
