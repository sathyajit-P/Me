---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allExperience = await getCollection('experience');
---

<Layout title="Experience | Portfolio">
  <section class="py-12 max-w-3xl mx-auto">
    <h1 class="font-display text-5xl mb-12 relative inline-block tracking-tight">My <span class="text-gradient">Experience</span></h1>
    
    <div class="relative pl-8 flex flex-col gap-12 before:content-[''] before:absolute before:left-0 before:top-2 before:h-full before:w-0.5 before:bg-zinc-200">
      {allExperience.map((exp) => (
        <div class="relative card">
          <div class="absolute -left-[2.35rem] top-8 w-3.5 h-3.5 bg-red rounded-full shadow-[0_0_0_4px_white,0_0_0_6px_rgba(16,185,129,0.2)]"></div>
          <div>
            <span class="inline-block font-sans text-sm font-bold text-red mb-2 tracking-wider uppercase">{exp.data.period}</span>
            <h2 class="font-display text-2xl font-bold mb-1">{exp.data.role}</h2>
            <h3 class="font-display text-lg text-zinc-500 font-medium mb-4">{exp.data.company}</h3>
            <p class="font-sans text-zinc-600 leading-relaxed">{exp.body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
