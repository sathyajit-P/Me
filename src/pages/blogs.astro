---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allBlogs = await getCollection('blogs');
---

<Layout title="Blogs | Portfolio">
  <section class="py-12">
    <h1 class="font-display text-5xl mb-12 relative inline-block tracking-tight">My <span class="text-gradient">Blogs</span></h1>
    
    <div class="flex flex-col gap-8 max-w-3xl">
      {allBlogs.length > 0 ? (
        allBlogs.map((blog) => (
          <a href={`/blogs/${blog.id}`} class="card block relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-1 h-0 bg-red transition-all duration-300 group-hover:h-full"></div>
            
            <div class="mb-3">
              <span class="font-sans text-sm font-semibold text-red uppercase tracking-wider">{blog.data.date}</span>
            </div>
            <h2 class="font-display text-2xl font-bold mb-4 transition-colors duration-300 group-hover:text-red">{blog.data.title}</h2>
            <p class="font-sans text-zinc-500 mb-6 leading-relaxed">{blog.data.excerpt}</p>
            <span class="font-sans text-sm font-bold text-zinc-900 flex items-center gap-2 opacity-80 transition-all duration-300 group-hover:opacity-100 group-hover:text-red group-hover:translate-x-1">
              Read article ➔
            </span>
          </a>
        ))
      ) : (
        <div class="card bg-zinc-50 border-dashed border-2 text-center py-16">
          <p class="font-sans text-lg text-zinc-500 mb-2">No blogs published yet.</p>
          <p class="font-sans text-sm text-zinc-400">Check back later for my thoughts on web development!</p>
        </div>
      )}
    </div>
  </section>
</Layout>
